{
  "expo": {
    "name": "Power Cabinet",
    "slug": "power-cabinet",
    "version": "1.0.0",
    "description": "Draft a fantasy cabinet of world leaders, chase promise points, and survive the truth tax.",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "powercabinet",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.agentpay.powercabinet",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.agentpay.powercabinet",
      "versionCode": 2,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#f3ead7",
          "dark": {
            "backgroundColor": "#f3ead7"
          }
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9ec7c128-9304-488e-a828-8aae08c56cdf"
      }
    },
    "owner": "rumblingb"
  }
}
